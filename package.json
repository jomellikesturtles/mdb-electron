{
  "name": "mdb-electron",
  "version": "0.0.0",
  "main": "main.js",
  "productName": "mdb",
  "private": true,
  "engines": {},
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:prod": "ng serve --configuration production",
    "build:web:dev": "ng build --configuration development",
    "build:web:prod": "ng build --configuration production",
    "build:electron:dev": "ng build --configuration development --base-href ./",
    "build:electron:prod": "ng build --configuration production --base-href ./",
    "start:electron:dev": "npm run build:electron:dev && electron .",
    "start:electron:prod": "npm run build:electron:prod && electron .",
    "test": "ng test",
    "test:coverage": "ng test --code-coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "e2e": "ng e2e",
    "\n# ELECTRON SCRIPTS": "",
    "electron": "electron .",
    "electron-logging": "electron . --enable-logging",
    "\n# STARTING ANGULAR AND NODE SERVER": "",
    "start:server": "node src/assets/scripts/server/main",
    "pack": "electron-packager ./ --overwrite",
    "pack:mac-arm64": "electron-packager . --platform=darwin --arch=arm64 --overwrite",
    "clean:install": "rm -rf node_modules && rm -rf package-lock.json && npm cache clean --force && npm install --legacy-peer-deps",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "electron-start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish"
  },
  "dependencies": {
    "chardet": "^1.3.0",
    "check-disk-space": "^3.0.1",
    "express": "^4.17.1",
    "fast-csv": "^3.4.0",
    "fast-folder-size": "^1.6.1",
    "fast-levenshtein": "^2.0.6",
    "fluent-ffmpeg": "^2.1.2",
    "jschardet": "^2.2.1",
    "moment": "^2.27.0",
    "nedb": "^1.8.0",
    "openpgp": "^6.3.0",
    "papaparse": "^5.0.1",
    "request": "^2.88.0",
    "subtitle": "^4.0.1",
    "uuid": "^8.3.0",
    "webtorrent": "2.8.5"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.17",
    "@angular/animations": "^17.3.12",
    "@angular/cdk": "^17.3.10",
    "@angular/cli": "^17.3.17",
    "@angular/common": "^17.3.12",
    "@angular/compiler": "^17.3.12",
    "@angular/compiler-cli": "^17.3.12",
    "@angular/core": "^17.3.12",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^17.3.12",
    "@angular/language-service": "^17.3.12",
    "@angular/material": "^17.3.10",
    "@angular/platform-browser": "^17.3.12",
    "@angular/platform-browser-dynamic": "^17.3.12",
    "@angular/pwa": "~0.803.28",
    "@angular/router": "^17.3.12",
    "@angular/service-worker": "^17.3.12",
    "@babel/core": "^7.18.9",
    "@compodoc/compodoc": "^1.1.19",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron/get": "^4.0.2",
    "@electron/rebuild": "^4.0.3",
    "@ngxs/devtools-plugin": "^3.8.2",
    "@ngxs/storage-plugin": "^3.8.2",
    "@ngxs/store": "^3.8.2",
    "@types/electron": "^1.6.10",
    "@types/jasmine": "~3.10.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/jest": "^26.0.15",
    "@types/mocha": "^8.0.4",
    "@types/nedb": "^1.8.12",
    "@types/node": "^12.11.1",
    "@types/uuid": "^8.3.0",
    "@types/webrtc": "0.0.26",
    "@types/webtorrent": "^0.107.1",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "ajv": "^7.2.4",
    "angular": "^1.7.8",
    "angular-user-idle": "^2.2.4",
    "asar": "^2.0.1",
    "babel-loader": "^8.2.5",
    "codelyzer": "^5.0.1",
    "core-js": "^2.5.4",
    "electron": "^40.6.1",
    "electron-squirrel-startup": "^1.0.1",
    "eslint": "^8.57.0",
    "hammerjs": "^2.0.8",
    "jasmine-core": "~4.0.0",
    "jasmine-spec-reporter": "~5.0.0",
    "jshint": "^2.13.6",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "ngx-cacheable": "^1.3.2",
    "ngx-electron": "^2.2.0",
    "path": "^0.12.7",
    "popper": "^1.0.1",
    "protractor": "~7.0.0",
    "rimraf": "^3.0.2",
    "rxjs": "~7.5.0",
    "ts-node": "~7.0.0",
    "tsc": "^1.20150623.0",
    "tslib": "^2.3.0",
    "typescript": "~5.4.5",
    "zone.js": "~0.14.10"
  },
  "files": [
    "*.js",
    "build",
    "node_modules"
  ],
  "electronWebpack": {
    "externals": {
      "nedb": "commonjs nedb"
    }
  }
}
